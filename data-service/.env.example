# Data Service 本地开发环境变量
# 复制此文件为 .env 并填入真实值

# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATA_SERVICE_TENANT_AUTH_REQUIRED=true
DATA_SERVICE_INTERNAL_TOKEN=

# === 缓存 ===
REDIS_URL=redis://localhost:6379/0

# === 历史行情缓存 ===
HISTORICAL_STORAGE_BACKEND=supabase_storage
HISTORICAL_STORAGE_FILE_ROOT=.historical-cache
HISTORICAL_MANIFEST_BACKEND=supabase_storage
HISTORICAL_MANIFEST_FILE_ROOT=.historical-manifests

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === Futu 本地 Connector ===
FUTU_CONNECTOR_PAIRING_TOKEN=

# === 数据源 (可选) ===
TUSHARE_TOKEN=
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=

# === 支付 (可选) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === 监控 (可选) ===
SENTRY_DSN=
