# AI Holdings Analyzer 3.0 - Mac mini Local Deployment

DEPLOYMENT_MODE=local_macmini
OPENCLAW_DEPLOYMENT_MODE=local_macmini
INSTANCE_ID=ai-holdings-macmini-01
OPENCLAW_INSTANCE_ID=ai-holdings-macmini-01
APP_VERSION=3.0.0-p0

WEBAPP_HTTP_PORT=3000
DATA_SERVICE_PORT=8000
OPENCLAW_PORT=8080
WEBAPP_BASE_URL=http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

INTERNAL_HOST_BIND=127.0.0.1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=ai_holdings
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_BUCKET_MARKET_DATA=market-data
MINIO_BUCKET_ARTIFACTS=hermes-artifacts
MINIO_BUCKET_REPLAYS=replay-evidence
MINIO_BUCKET_MEDIA=tenant-media

DATA_SERVICE_URL=http://data-service:8000
NEXT_PUBLIC_DATA_SERVICE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_OPENCLAW_URL=http://127.0.0.1:8080
REDIS_URL=redis://redis:6379/0

AUTH_MODE=local
AUTH_SESSION_SECRET=change-this-to-a-long-random-string
AUTH_COOKIE_SECURE=false
LOCAL_AUTH_ENABLED=true
LOCAL_AUTH_EMAIL=admin@ai-holdings.local
LOCAL_AUTH_PASSWORD=change-this-local-admin-password
LOCAL_AUTH_DISPLAY_NAME=本地管理员
LOCAL_AUTH_ROLE=admin
LOCAL_AUTH_USER_ID=00000000-0000-0000-0000-000000000000
LOCAL_AUTH_REGISTRATION_ENABLED=true
AUTH_VERIFICATION_TTL_MINUTES=30
AUTH_VERIFICATION_MAX_ATTEMPTS=5
AUTH_EMAIL_APP_NAME=AI 持仓分析系统
AUTH_EXPOSE_LOCAL_CODE=false

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

OPENCLAW_UPSTREAM_TARGET_VERSION=v2026.5.27
HERMES_UPSTREAM_TARGET_VERSION=v2026.5.29
GBRAIN_ADAPTER_VERSION=0.2.0
OPENCLAW_DEFAULT_PLAN=basic
OPENCLAW_SKILL_KEY=change-this-openclaw-skill-key
OPENCLAW_DELIVERY_MODE=log
OPENCLAW_DELIVERY_WEBHOOK_URL=
OPENCLAW_DELIVERY_WEBHOOK_SECRET=
OPENCLAW_OUTBOX_REPOSITORY=postgres
OPENCLAW_POST_CONFIRMATION_REPOSITORY=postgres
OPENCLAW_CONFIRMATION_REPOSITORY=postgres

WECHAT_CLAWBOT_API_BASE_URL=https://ilinkai.weixin.qq.com
WECHAT_ILINK_APP_ID=
WECHAT_ILINK_CLIENT_VERSION=
WECHAT_CLAWBOT_POLL_INTERVAL_SECONDS=5
ONBOARDING_CREDENTIAL_ENCRYPTION_KEY=change-this-32-byte-encryption-key

GBRAIN_DATABASE_CONNECT_RETRIES=12
GBRAIN_DATABASE_CONNECT_RETRY_DELAY_MS=5000
GBRAIN_LIVE_MODELS_ENABLED=true
MODEL_ADAPTER_MODE=live
MODEL_AUTH_MODE=api_key
HERMES_WORKER_MODE=live
HERMES_LIGHT_MODEL=MiniMax-M2.7
HERMES_DEEP_PROVIDER=openai
HERMES_DEEP_MODEL=gpt-5.5
HERMES_LIGHT_TASK_TIMEOUT_SECONDS=300
HERMES_DEEP_TASK_TIMEOUT_SECONDS=1800
HERMES_CONTEXT_PACK_MAX_TOKENS=24000
HERMES_ARTIFACT_STORAGE_BACKEND=file
HERMES_ARTIFACT_BASE_URI=file://hermes-artifacts

MINIMAX_API_KEY=
MINIMAX_BASE_URL=
