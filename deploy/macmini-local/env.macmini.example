MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_API_FORMAT=anthropic
MINIMAX_MAX_TOKENS=2048
MINIMAX_ANTHROPIC_STREAMING=true
OPENCLAW_IMAGE_VISION_ENABLED=true
OPENCLAW_IMAGE_VISION_API_ATTEMPTS=3

OPENAI_API_KEY=
GBRAIN_OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CODEX_AUTH_PROFILE=
OPENAI_CODEX_BRIDGE_BASE_URL=
OPENAI_CODEX_BRIDGE_API_KEY=

FUTU_CONNECTOR_MODE=local_mock
