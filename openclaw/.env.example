# ============================================================
# OpenClaw Gateway — 云端部署环境变量
# ============================================================
# 用于 Cloud Run 部署，敏感值存入 Google Secret Manager

# === 部署模式 ===
DEPLOYMENT_MODE=cloud
OPENCLAW_DEPLOYMENT_MODE=cloud
INSTANCE_ID=openclaw-gateway-prod-01

# === Supabase (通过 Secret Manager 注入) ===
SUPABASE_URL=https://jpceuvtjhuafqscyabdg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=  # → Secret Manager: supabase-service-role-key
SUPABASE_ANON_KEY=          # → Secret Manager: supabase-anon-key
SUPABASE_JWT_SECRET=        # → Secret Manager: supabase-jwt-secret

# === 微信小程序 ===
WECHAT_APP_ID=              # → Secret Manager: wechat-app-id
WECHAT_APP_SECRET=          # → Secret Manager: wechat-app-secret

# === AI ===
OPENAI_API_KEY=             # → Secret Manager: openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# === 数据源 ===
TUSHARE_TOKEN=              # → Secret Manager: tushare-token
DATA_SERVICE_URL=http://data-service:8000  # Cloud Run 内网

# === 缓存 ===
REDIS_URL=                  # Upstash Redis URL

# === 支付 ===
STRIPE_SECRET_KEY=          # → Secret Manager
STRIPE_WEBHOOK_SECRET=      # → Secret Manager

# === 监控 ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=2.0.0

# === Gateway 专属 ===
OPENCLAW_SKILL_KEY=         # Skill 级 API Key (默认复用 service_role)
OPENCLAW_WEBHOOK_SECRET=    # Webhook HMAC 签名密钥
OPENCLAW_CRON_SECRET=       # Cron 端点验证密钥 (本地开发用)

# === CORS ===
CORS_ALLOWED_ORIGINS=https://your-domain.vercel.app,https://your-custom-domain.com

# === gbrain 记忆 ===
GBRAIN_MCP_ADAPTER_PATH=/app/gbrain/src/mcp-adapter.ts
GBRAIN_MCP_RUNTIME=bun
GBRAIN_EMBEDDING_MODEL=text-embedding-3-small
