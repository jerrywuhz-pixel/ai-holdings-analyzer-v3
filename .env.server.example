# ============================================================
# AI Holdings Analyzer 3.0 - Lightweight Server P0 Template
# ============================================================
# Copy this file on the server:
#   cp .env.server.example .env.server
#
# First-stage target:
#   WebApp public access + data-service health + graceful fallback UI.
# P0 full local-server target:
#   WebApp + data-service + Redis + Postgres + MinIO + OpenClaw + GBrain/Hermes
#   run on one lightweight server. Real brokerage and channel credentials stay
#   opt-in and are never guessed.

DEPLOYMENT_MODE=lightweight_server
INSTANCE_ID=ai-holdings-lightweight-01
APP_VERSION=3.0.0-p0

# Replace YOUR_SERVER_IP with the public IP of your lightweight server.
WEBAPP_HTTP_PORT=3000
OPENCLAW_PORT=8080
WEBAPP_BASE_URL=http://YOUR_SERVER_IP:3000
CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP:3000,http://localhost:3000

# Local server storage. These are local-only defaults for P0 smoke deployment.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_holdings
# Default docker-compose.server.yml uses Docker service DNS for inter-container
# traffic. If bridge traffic is fully blocked, use docker-compose.lightweight-host.yml
# and change these host values to 127.0.0.1 as documented.
INTERNAL_HOST_BIND=172.17.0.1
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_MARKET_DATA=market-data
MINIO_BUCKET_ARTIFACTS=hermes-artifacts
MINIO_BUCKET_REPLAYS=replay-evidence
MINIO_BUCKET_MEDIA=tenant-media
TUSHARE_TOKEN=
FTSHARE_MARKET_DATA_SKILL_DIR=/app/skills/ftshare-market-data
FTSHARE_MARKET_DATA_TIMEOUT_SECONDS=10

# The WebApp server runs inside Docker and calls data-service through service DNS.
DATA_SERVICE_URL=http://data-service:8000
NEXT_PUBLIC_DATA_SERVICE_URL=http://data-service:8000
NEXT_PUBLIC_OPENCLAW_URL=

# Optional Supabase/Auth values. Leave empty in the first smoke test; core P0
# pages will show a clear reference/fallback state until real data is connected.
AUTH_MODE=auto
AUTH_SESSION_SECRET=change-this-to-a-long-random-string
AUTH_COOKIE_SECURE=false
LOCAL_AUTH_ENABLED=true
LOCAL_AUTH_EMAIL=admin@ai-holdings.local
LOCAL_AUTH_PASSWORD=change-this-local-password
LOCAL_AUTH_DISPLAY_NAME=本地管理员
LOCAL_AUTH_ROLE=admin
LOCAL_AUTH_USER_ID=00000000-0000-0000-0000-000000000000
LOCAL_AUTH_REGISTRATION_ENABLED=true
AUTH_VERIFICATION_TTL_MINUTES=10
AUTH_VERIFICATION_MAX_ATTEMPTS=5
AUTH_EMAIL_APP_NAME="AI 持仓分析系统"
AUTH_EXPOSE_LOCAL_CODE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Redis is used by data-service for lightweight health/cache paths.
REDIS_URL=redis://host.docker.internal:6379/0

# OpenClaw / broker write features stay disabled or read-only in first stage.
# Set GBRAIN_LIVE_MODELS_ENABLED=true and provide MINIMAX_API_KEY when running
# the lightweight readiness gate with MiniMax M2.7 live routing.
OPENCLAW_DEPLOYMENT_MODE=lightweight_server
OPENCLAW_INSTANCE_ID=ai-holdings-lightweight-01
OPENCLAW_UPSTREAM_TARGET_VERSION=v2026.5.18
OPENCLAW_DEFAULT_PLAN=basic
OPENCLAW_SKILL_KEY=
OPENCLAW_DELIVERY_MODE=webhook
OPENCLAW_DELIVERY_WEBHOOK_URL=http://127.0.0.1:3000/api/openclaw/delivery/wechat
OPENCLAW_DELIVERY_WEBHOOK_SECRET=
OPENCLAW_GATEWAY_REPOSITORY=postgres
OPENCLAW_OUTBOX_REPOSITORY=postgres
OPENCLAW_POST_CONFIRMATION_REPOSITORY=postgres
WECHAT_CLAWBOT_API_BASE_URL=https://ilinkai.weixin.qq.com
WECHAT_ILINK_APP_ID=
WECHAT_ILINK_CLIENT_VERSION=
ONBOARDING_CREDENTIAL_ENCRYPTION_KEY=
HERMES_UPSTREAM_TARGET_VERSION=v2026.5.16
GBRAIN_ADAPTER_VERSION=0.2.0
GBRAIN_DATABASE_CONNECT_RETRIES=12
GBRAIN_DATABASE_CONNECT_RETRY_DELAY_MS=5000
GBRAIN_LIVE_MODELS_ENABLED=false
MODEL_ADAPTER_MODE=stub
MODEL_AUTH_MODE=api_key
HERMES_WORKER_MODE=stub
HERMES_LIGHT_MODEL=MiniMax-M2.7
HERMES_DEEP_PROVIDER=openai
HERMES_DEEP_MODEL=gpt-5.5
HERMES_AUTH_PROFILE_ID=
HERMES_LIGHT_TASK_TIMEOUT_SECONDS=300
HERMES_DEEP_TASK_TIMEOUT_SECONDS=1800
HERMES_CONTEXT_PACK_MAX_TOKENS=24000
HERMES_ARTIFACT_STORAGE_BACKEND=file
HERMES_ARTIFACT_BASE_URI=file://hermes-artifacts
BROKER_SYNC_REPOSITORY=postgres
FUTU_CONNECTOR_MODE=local_mock
FUTU_CONNECTOR_READ_ONLY=true
FUTU_CONNECTOR_BASE_URL=http://host.docker.internal:8765
FUTU_CONNECTOR_POLL_ENDPOINT=http://YOUR_SERVER_IP/api/v3/connectors/poll
FUTU_CONNECTOR_UPLOAD_ENDPOINT=http://YOUR_SERVER_IP/api/v3/connectors/upload
FUTU_CONNECTOR_PAIRING_TOKEN=
FUTU_CONNECTOR_CLOUD_ENABLED=false
SELL_PUT_FRESHNESS_SECONDS=180
BROKER_SNAPSHOT_MAX_STALENESS_SECONDS=900

# Public reference FX source. Frankfurter tracks daily reference rates from
# central banks / official institutions and does not require an API key.
FX_RATES_SOURCE=trusted_http_fx_frankfurter
FX_RATES_JSON=
FX_RATE_ENDPOINT=https://api.frankfurter.dev/v1/latest
FX_RATE_API_KEY=

# Optional live model keys. MiniMax is the first-stage light model route;
# OpenAI/Codex is required only for production deep research readiness.
OPENAI_API_KEY=
GBRAIN_OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=MiniMax-M2.7
ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M2.7
ANTHROPIC_DEFAULT_OPUS_MODEL=MiniMax-M2.7
ANTHROPIC_DEFAULT_HAIKU_MODEL=MiniMax-M2.7
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_API_FORMAT=anthropic
MINIMAX_MAX_TOKENS=2048
MINIMAX_ANTHROPIC_STREAMING=true
OPENCLAW_MINIMAX_CLI_ENABLED=false
OPENCLAW_MINIMAX_MODEL=minimax-portal/MiniMax-M2.7
OPENCLAW_CLI_PATH=openclaw

# Optional system-level OpenAI Codex auth bridge.
# For Mac mini/local nodes: run an OpenClaw/Hermes bridge that owns the
# openai-codex auth profile, then point this service to that bridge.
OPENAI_CODEX_AUTH_PROFILE=
OPENAI_CODEX_BRIDGE_BASE_URL=
OPENAI_CODEX_BRIDGE_API_KEY=

# Optional IMA reference source. Reference-only; never a portfolio fact source.
IMA_REFERENCE_SOURCE_ENABLED=false
IMA_OPENAPI_CLIENTID=
IMA_OPENAPI_APIKEY=
IMA_DEFAULT_KNOWLEDGE_BASE_ID=
IMA_SKILL_VERSION=1.1.7

OBSERVABILITY_BACKEND=docker_logs
LOG_RETENTION_DAYS=14
ALIYUN_SLS_PROJECT=
ALIYUN_SLS_LOGSTORE=
SENTRY_DSN=
SENTRY_ENVIRONMENT=lightweight_server
SENTRY_RELEASE=3.0.0-p0
