# ============================================================
# AI Holdings Analyzer 3.0 P0 — Local/Cloud Environment Template
# ============================================================
# Local:
#   cp .env.example .env
#   ./scripts/init-local.sh
#
# Verification:
#   ./scripts/verify-p0.sh
#   python3 scripts/e2e_smoke.py --mode mock

# === Deployment ===
DEPLOYMENT_MODE=local
INSTANCE_ID=ai-holdings-local-01

# === Core Ports ===
WEBAPP_PORT=3000
DATA_SERVICE_PORT=8000
OPENCLAW_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# === Postgres / Redis ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_holdings
REDIS_URL=redis://localhost:6379/0

# === Supabase Auth / Database ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=dev-jwt-secret
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:5432/ai_holdings

# === Supabase Storage / Local Object Storage ===
OBJECT_STORAGE_PROVIDER=minio
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_PUBLIC_BASE_URL=http://localhost:9000
OBJECT_STORAGE_PATH_STYLE=true

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_MARKET_DATA=market-data
MINIO_BUCKET_ARTIFACTS=hermes-artifacts
MINIO_BUCKET_REPLAYS=replay-evidence
MINIO_BUCKET_MEDIA=tenant-media

SUPABASE_STORAGE_BUCKET_MARKET_DATA=market-data
SUPABASE_STORAGE_BUCKET_ARTIFACTS=hermes-artifacts
SUPABASE_STORAGE_BUCKET_REPLAYS=replay-evidence
SUPABASE_STORAGE_BUCKET_MEDIA=tenant-media

# Hermes reports and historical market data can run on local files in P0.
# Production should switch these to Supabase Storage buckets.
HERMES_ARTIFACT_STORAGE_BACKEND=file
HERMES_ARTIFACT_BASE_URI=file://hermes-artifacts
HERMES_ARTIFACT_FILE_ROOT=.artifacts/hermes
HISTORICAL_STORAGE_BACKEND=file
HISTORICAL_STORAGE_FILE_ROOT=.historical-cache

# === OpenClaw / Delivery ===
OPENCLAW_WEBHOOK_SECRET=whsec_local_dev
OPENCLAW_CRON_SECRET=cron_local_dev
OPENCLAW_SKILL_KEY=
OPENCLAW_INSTANCE_ID=openclaw-local-01
OPENCLAW_UPSTREAM_TARGET_VERSION=v2026.5.18
OPENCLAW_DEFAULT_PLAN=basic
DELIVERY_RATE_LIMIT_PER_HOUR=6
OPENCLAW_DELIVERY_MODE=log
OPENCLAW_DELIVERY_WEBHOOK_URL=
OPENCLAW_DELIVERY_WEBHOOK_SECRET=
OPENCLAW_DELIVERY_TIMEOUT_SECONDS=10
OPENCLAW_OUTBOX_WORKER_LIMIT=50
OPENCLAW_OUTBOX_WORKER_POLL_INTERVAL_SECONDS=2
QUIET_HOURS_DEFAULT_START=22:00
QUIET_HOURS_DEFAULT_END=08:00

# === WeChat / Channel Binding ===
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_WEBSITE_APP_ID=
WECHAT_WEBSITE_APP_SECRET=
WECHAT_CLAWBOT_API_BASE_URL=https://ilinkai.weixin.qq.com

# === AI / Model Adapter ===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GBRAIN_OPENAI_BASE_URL=
GBRAIN_OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_OPENAI_BASE_URL=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_API_FORMAT=anthropic
MINIMAX_MAX_TOKENS=2048

GBRAIN_LIVE_MODELS_ENABLED=false
MODEL_ADAPTER_MODE=stub
MODEL_AUTH_MODE=api_key
MODEL_ADAPTER_BASE_URL=http://localhost:8090
MODEL_ADAPTER_PRIMARY_PROVIDER=minimax
MODEL_ADAPTER_FALLBACK_PROVIDER=openai
MODEL_ADAPTER_TIMEOUT_SECONDS=45

# Optional system-level Codex subscription auth bridge.
# The bridge is a trusted local/OpenClaw/Hermes service that already owns the
# OpenAI Codex OAuth profile and exposes an OpenAI-compatible chat endpoint.
OPENAI_CODEX_AUTH_PROFILE=
OPENAI_CODEX_BRIDGE_BASE_URL=
OPENAI_CODEX_BRIDGE_API_KEY=

# === Hermes Worker / Job Runtime ===
HERMES_WORKER_MODE=stub
HERMES_UPSTREAM_TARGET_VERSION=v2026.5.16
GBRAIN_ADAPTER_VERSION=0.2.0
GBRAIN_DATABASE_CONNECT_RETRIES=12
GBRAIN_DATABASE_CONNECT_RETRY_DELAY_MS=5000
HERMES_QUEUE_NAME=hermes-jobs
HERMES_LIGHT_MODEL=MiniMax-M2.7
HERMES_DEEP_PROVIDER=openai
HERMES_DEEP_MODEL=gpt-5.5
HERMES_AUTH_PROFILE_ID=
HERMES_LIGHT_TASK_TIMEOUT_SECONDS=300
HERMES_DEEP_TASK_TIMEOUT_SECONDS=1800
HERMES_CONTEXT_PACK_MAX_TOKENS=24000
HERMES_MAX_CONCURRENT_JOBS=2
HERMES_ARTIFACT_TTL_DAYS=90
MEDIA_ARTIFACT_TTL_DAYS=30
POST_CONFIRMATION_WORKER_BATCH_LIMIT=20
POST_CONFIRMATION_WORKER_POLL_INTERVAL_SECONDS=5

# === Confirmation / Policy ===
CONFIRMATION_HIGH_RISK_TTL_MINUTES=30
CONFIRMATION_LOW_RISK_TTL_MINUTES=1440
SELL_PUT_FRESHNESS_SECONDS=60
BROKER_SNAPSHOT_MAX_STALENESS_SECONDS=60

# === Broker / Futu Local Connector ===
FUTU_CONNECTOR_MODE=local_mock
FUTU_CONNECTOR_BASE_URL=http://localhost:8765
FUTU_CONNECTOR_HEARTBEAT_PATH=/health
FUTU_CONNECTOR_SNAPSHOT_PATH=/api/v1/snapshots
FUTU_CONNECTOR_OPTION_CHAIN_PATH=/api/v1/option-chain
FUTU_CONNECTOR_TIMEOUT_SECONDS=8
FUTU_CONNECTOR_READ_ONLY=true
FUTU_CONNECTOR_PAIRING_TOKEN=
FUTU_SIDECAR_MODE=mock
FUTU_SIDECAR_HOST=127.0.0.1
FUTU_SIDECAR_PORT=8765
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111
FUTU_TRD_MARKET=US
FUTU_SECURITY_FIRM=FUTUSECURITIES
FUTU_TRD_ENV=REAL
FUTU_CURRENCY=USD
FUTU_ACC_ID=0
FUTU_ACC_INDEX=0
FUTU_SDK_MODULE=futu
FUTU_MAX_SNAPSHOT_CODES=400

# === Market Data Sources ===
TUSHARE_TOKEN=
FTSHARE_MARKET_DATA_SKILL_DIR=./openclaw/skills/ftshare-market-data
FTSHARE_MARKET_DATA_TIMEOUT_SECONDS=10
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=

# === IMA Reference Source ===
# Get credentials from https://ima.qq.com/agent-interface
IMA_OPENAPI_CLIENTID=
IMA_OPENAPI_APIKEY=
IMA_BASE_URL=https://ima.qq.com
IMA_SKILL_VERSION=1.1.7
IMA_SKILL_DIR=./openclaw/skills/ima-skill
IMA_DEFAULT_KNOWLEDGE_BASE_ID=
IMA_REFERENCE_SOURCE_ENABLED=false

# Trusted FX for portfolio valuation.
# Local fallback is intentionally marked as estimate in user-facing output.
FX_RATES_SOURCE=fallback_estimate
FX_RATES_JSON=
FX_RATE_ENDPOINT=
FX_RATE_API_KEY=
FX_RATE_TIMEOUT_SECONDS=5

# === CORS / Frontend ===
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WEBAPP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
DATA_SERVICE_URL=http://localhost:8000
DATA_SERVICE_TENANT_AUTH_REQUIRED=false
DATA_SERVICE_INTERNAL_TOKEN=
ONBOARDING_CREDENTIAL_ENCRYPTION_KEY=

# === gbrain Memory Storage ===
GBRAIN_MCP_ADAPTER_PATH=./gbrain/src/mcp-adapter.ts
GBRAIN_MCP_RUNTIME=bun
GBRAIN_EMBEDDING_MODEL=text-embedding-3-small
GBRAIN_DATABASE_URL=

# === Monitoring / Billing (Optional) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=3.0.0-p0

# === Smoke / Verification Hooks ===
SMOKE_WEBAPP_URL=http://localhost:3000
SMOKE_DATA_SERVICE_URL=http://localhost:8000
SMOKE_OPENCLAW_URL=http://localhost:8080
SMOKE_DELIVERY_MODE=log
SMOKE_TENANT_ENDPOINT=
SMOKE_BROKER_SNAPSHOT_ENDPOINT=
SMOKE_PORTFOLIO_ENDPOINT=
SMOKE_SELL_PUT_ENDPOINT=
SMOKE_CONFIRMATION_ENDPOINT=
SMOKE_DELIVERY_ENDPOINT=
