# ============================================================
# AI Holdings Analyzer 3.0 P0 - Alibaba Cloud Production Template
# ============================================================
# Copy values into Alibaba Cloud KMS Secrets Manager / SAE env.
# Do not commit a filled production env file.

# === Deployment Target ===
DEPLOYMENT_MODE=cloud
CLOUD_PROVIDER=aliyun
ALIYUN_REGION=cn-shanghai
ALIYUN_ACCOUNT_ID=
ALIYUN_PROFILE=default

# === Domain / ICP ===
WEBAPP_BASE_URL=https://app.example.cn
CORS_ALLOWED_ORIGINS=https://app.example.cn
NEXT_PUBLIC_DATA_SERVICE_URL=https://api.example.cn
DATA_SERVICE_URL=https://api.example.cn
ICP_BEIAN_NUMBER=

# === Alibaba Cloud Runtime ===
ALIYUN_ACR_REGISTRY=registry.cn-shanghai.aliyuncs.com
ALIYUN_ACR_NAMESPACE=ai-holdings
ALIYUN_SAE_NAMESPACE_ID=
ALIYUN_SAE_WEBAPP_APP_ID=
ALIYUN_SAE_GATEWAY_APP_ID=
ALIYUN_SAE_DATA_SERVICE_APP_ID=
ALIYUN_SAE_GBRAIN_WORKER_APP_ID=

# === Alibaba Cloud Managed State ===
ALIYUN_RDS_INSTANCE_ID=
ALIYUN_REDIS_INSTANCE_ID=
DATABASE_URL=postgresql://user:password@rds-internal-host:5432/ai_holdings
REDIS_URL=redis://redis-internal-host:6379/0

# === Alibaba Cloud OSS ===
HERMES_ARTIFACT_STORAGE_BACKEND=supabase
HERMES_ARTIFACT_BASE_URI=supabase://hermes-artifacts
HISTORICAL_STORAGE_BACKEND=supabase_storage
SUPABASE_STORAGE_BUCKET_MARKET_DATA=ai-holdings-market-data
SUPABASE_STORAGE_BUCKET_ARTIFACTS=ai-holdings-artifacts
SUPABASE_STORAGE_BUCKET_REPLAYS=ai-holdings-replay
SUPABASE_STORAGE_BUCKET_MEDIA=ai-holdings-media
ALIYUN_OSS_BUCKET_MARKET_DATA=ai-holdings-market-data
ALIYUN_OSS_BUCKET_ARTIFACTS=ai-holdings-artifacts
ALIYUN_OSS_BUCKET_REPLAY=ai-holdings-replay
ALIYUN_OSS_BUCKET_MEDIA=ai-holdings-media

# === Alibaba Cloud Scheduler / Observability ===
ALIYUN_EVENTBRIDGE_BUS=ai-holdings
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=3.0.0-p0

# === Supabase Compatibility / Auth Boundary ===
# P0 code still expects Supabase-compatible REST/Auth env in several paths.
# If production moves runtime state to Alibaba Cloud RDS, keep these pointed at
# the chosen compatibility/auth boundary until those call sites are migrated.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATA_SERVICE_TENANT_AUTH_REQUIRED=true
DATA_SERVICE_INTERNAL_TOKEN=
ONBOARDING_CREDENTIAL_ENCRYPTION_KEY=

# === OpenClaw Delivery / WeChat ===
OPENCLAW_DELIVERY_MODE=webhook
OPENCLAW_DELIVERY_WEBHOOK_URL=https://api.example.cn/openclaw/delivery
OPENCLAW_DELIVERY_WEBHOOK_SECRET=
OPENCLAW_DELIVERY_TIMEOUT_SECONDS=10
OPENCLAW_WECHAT_SKIP_CONFIRMATION_CENTER=true
OPENCLAW_SKIP_GATEWAY_SYSTEM_DELIVERIES=true
OPENCLAW_WECHAT_SUPPRESSED_DELIVERY_CONTENT_TYPES=confirmation_card,task_update
OPENCLAW_OUTBOX_WORKER_LIMIT=50
OPENCLAW_CRON_SECRET=
OPENCLAW_SKILL_KEY=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_WEBSITE_APP_ID=
WECHAT_WEBSITE_APP_SECRET=
WECHAT_CLAWBOT_API_BASE_URL=https://ilinkai.weixin.qq.com

# === Live Model Provider ===
GBRAIN_LIVE_MODELS_ENABLED=true
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GBRAIN_OPENAI_API_KEY=
GBRAIN_OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MINIMAX_API_KEY=
MINIMAX_OPENAI_BASE_URL=
MINIMAX_MODEL=minimax-m2.7
MODEL_ADAPTER_PRIMARY_PROVIDER=minimax
MODEL_ADAPTER_FALLBACK_PROVIDER=openai
MODEL_ADAPTER_TIMEOUT_SECONDS=45

# === Hermes Runtime ===
HERMES_WORKER_MODE=live
HERMES_LIGHT_MODEL=minimax-m2.7
HERMES_DEEP_MODEL=gpt-5.5
HERMES_LIGHT_TASK_TIMEOUT_SECONDS=300
HERMES_DEEP_TASK_TIMEOUT_SECONDS=1800
HERMES_CONTEXT_PACK_MAX_TOKENS=24000
HERMES_MAX_CONCURRENT_JOBS=2
HERMES_ARTIFACT_TTL_DAYS=90

# === Trusted FX ===
FX_RATES_SOURCE=trusted_http_fx
FX_RATE_ENDPOINT=https://fx.example.cn/latest
FX_RATE_API_KEY=
FX_RATE_TIMEOUT_SECONDS=5
FX_RATES_JSON=

# === Broker / Futu Connector ===
FUTU_CONNECTOR_MODE=user_local_polling
FUTU_CONNECTOR_READ_ONLY=true
FUTU_CONNECTOR_POLL_ENDPOINT=https://api.example.cn/api/v3/connectors/poll
FUTU_CONNECTOR_UPLOAD_ENDPOINT=https://api.example.cn/api/v3/connectors/upload
FUTU_CONNECTOR_PAIRING_TOKEN=
FUTU_CONNECTOR_TIMEOUT_SECONDS=8
SELL_PUT_FRESHNESS_SECONDS=60
BROKER_SNAPSHOT_MAX_STALENESS_SECONDS=60

# === Market Data Sources ===
TUSHARE_TOKEN=
FTSHARE_MARKET_DATA_SKILL_DIR=/app/skills/ftshare-market-data
FTSHARE_MARKET_DATA_TIMEOUT_SECONDS=10
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
