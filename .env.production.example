# ============================================================
# AI Holdings Analyzer 3.0 P0 — Production Environment Template
# ============================================================
# Copy values into your secret manager or deployment environment.
# Do not commit a filled production env file.

# === Deployment Target ===
DEPLOYMENT_MODE=cloud
CLOUD_PROVIDER=aliyun
ALIYUN_REGION=cn-shanghai
GATEWAY_SERVICE=openclaw-gateway
DATA_SERVICE=data-service

# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# === WebApp / CORS ===
WEBAPP_BASE_URL=https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATA_SERVICE_URL=https://api.example.cn
NEXT_PUBLIC_DATA_SERVICE_URL=https://api.example.cn
DATA_SERVICE_TENANT_AUTH_REQUIRED=true
DATA_SERVICE_INTERNAL_TOKEN=
ONBOARDING_CREDENTIAL_ENCRYPTION_KEY=

# === OpenClaw Delivery ===
OPENCLAW_DELIVERY_MODE=webhook
OPENCLAW_DELIVERY_WEBHOOK_URL=https://openclaw-weixin.example.com/send
OPENCLAW_DELIVERY_WEBHOOK_SECRET=
OPENCLAW_DELIVERY_TIMEOUT_SECONDS=10
OPENCLAW_OUTBOX_WORKER_LIMIT=50
OPENCLAW_CRON_SECRET=
OPENCLAW_SKILL_KEY=

# === WeChat Binding ===
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_WEBSITE_APP_ID=
WECHAT_WEBSITE_APP_SECRET=
WECHAT_CLAWBOT_API_BASE_URL=https://ilinkai.weixin.qq.com

# === Live Model Provider ===
GBRAIN_LIVE_MODELS_ENABLED=true
GBRAIN_DATABASE_CONNECT_RETRIES=12
GBRAIN_DATABASE_CONNECT_RETRY_DELAY_MS=5000
MODEL_AUTH_MODE=api_key
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GBRAIN_OPENAI_API_KEY=
GBRAIN_OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

MINIMAX_API_KEY=
MINIMAX_OPENAI_BASE_URL=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_API_FORMAT=anthropic
MINIMAX_MAX_TOKENS=2048

MODEL_ADAPTER_PRIMARY_PROVIDER=minimax
MODEL_ADAPTER_FALLBACK_PROVIDER=openai
MODEL_ADAPTER_TIMEOUT_SECONDS=45

OPENAI_CODEX_AUTH_PROFILE=
OPENAI_CODEX_BRIDGE_BASE_URL=
OPENAI_CODEX_BRIDGE_API_KEY=

# === Hermes Runtime / Storage ===
HERMES_WORKER_MODE=live
HERMES_LIGHT_MODEL=MiniMax-M2.7
HERMES_DEEP_PROVIDER=openai
HERMES_DEEP_MODEL=gpt-5.5
HERMES_AUTH_PROFILE_ID=
HERMES_LIGHT_TASK_TIMEOUT_SECONDS=300
HERMES_DEEP_TASK_TIMEOUT_SECONDS=1800
HERMES_CONTEXT_PACK_MAX_TOKENS=24000
HERMES_MAX_CONCURRENT_JOBS=2
HERMES_ARTIFACT_STORAGE_BACKEND=supabase
HERMES_ARTIFACT_BASE_URI=supabase://hermes-artifacts
HERMES_ARTIFACT_TTL_DAYS=90

# === Historical Market Storage ===
HISTORICAL_STORAGE_BACKEND=supabase_storage
SUPABASE_STORAGE_BUCKET_MARKET_DATA=market-data
SUPABASE_STORAGE_BUCKET_ARTIFACTS=hermes-artifacts
SUPABASE_STORAGE_BUCKET_REPLAYS=replay-evidence
SUPABASE_STORAGE_BUCKET_MEDIA=tenant-media

# === Trusted FX ===
FX_RATES_SOURCE=trusted_http_fx
FX_RATE_ENDPOINT=https://fx.example.com/latest
FX_RATE_API_KEY=
FX_RATE_TIMEOUT_SECONDS=5
# Optional static override, for example: {"HKD:USD":0.1278,"CNY:USD":0.138}
FX_RATES_JSON=

# === Broker / Futu Connector ===
FUTU_CONNECTOR_MODE=user_local_polling
FUTU_CONNECTOR_READ_ONLY=true
FUTU_CONNECTOR_POLL_ENDPOINT=https://api.example.cn/api/v3/connectors/poll
FUTU_CONNECTOR_UPLOAD_ENDPOINT=https://api.example.cn/api/v3/connectors/upload
FUTU_CONNECTOR_PAIRING_TOKEN=
FUTU_CONNECTOR_TIMEOUT_SECONDS=8
SELL_PUT_FRESHNESS_SECONDS=60
BROKER_SNAPSHOT_MAX_STALENESS_SECONDS=60

# === Monitoring ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=3.0.0-p0
CLOUD_MONITOR_TIMEOUT_SECONDS=8

# === Market Data Sources ===
TUSHARE_TOKEN=
FTSHARE_MARKET_DATA_SKILL_DIR=/app/skills/ftshare-market-data
FTSHARE_MARKET_DATA_TIMEOUT_SECONDS=10
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
