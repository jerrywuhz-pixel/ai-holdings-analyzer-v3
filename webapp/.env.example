NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATA_SERVICE_URL=http://127.0.0.1:8000
DATA_SERVICE_INTERNAL_TOKEN=
WECHAT_CLAWBOT_API_BASE_URL=https://ilinkai.weixin.qq.com
ONBOARDING_CREDENTIAL_ENCRYPTION_KEY=
FUTU_CONNECTOR_PAIRING_TOKEN=

# Auth mode: auto | local | supabase
AUTH_MODE=local
AUTH_SESSION_SECRET=
AUTH_COOKIE_SECURE=false

# Local auth bootstrap account and self-service registration
LOCAL_AUTH_ENABLED=true
LOCAL_AUTH_EMAIL=admin@ai-holdings.local
LOCAL_AUTH_PASSWORD=
LOCAL_AUTH_DISPLAY_NAME=本地管理员
LOCAL_AUTH_ROLE=admin
LOCAL_AUTH_REGISTRATION_ENABLED=true
AUTH_VERIFICATION_TTL_MINUTES=10
AUTH_VERIFICATION_MAX_ATTEMPTS=5

# Optional: only for local smoke/dev. Do not enable in production.
AUTH_EXPOSE_LOCAL_CODE=false

# SMTP for registration verification codes. If omitted, codes are written to WebApp server logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
AUTH_EMAIL_APP_NAME=AI 持仓分析系统
